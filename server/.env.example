# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase (service role key — never expose this to the frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App
PORT=3001
FRONTEND_URL=http://localhost:5173

# Email (Resend)
RESEND_API_KEY=re_...

# Internal webhooks
WEBHOOK_URL=http://localhost:5678/webhook-test/...
WEBHOOK_SECRET=some-random-secret-string

# AI formatting passes (Step C/D) — via OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-oss-120b:free
AI_FORMATTING_ENABLED=false
# Determinism knobs — keep run-to-run heading results consistent
AI_TEMPERATURE=0          # 0 = greedy/deterministic decode
AI_SEED=7                 # fixed RNG seed where the provider honours it
# Pin routing to one backend so OpenRouter doesn't swap hardware between runs.
# Comma-separated provider slug(s), in preference order; leave empty to route freely.
# Find valid slugs on the model's OpenRouter page (Providers tab), e.g. "deepinfra,fireworks".
AI_PROVIDER=
# Tuning (optional)
AI_MAX_TOKENS=2048
AI_MAX_CHARS_PER_CHUNK=8000
AI_CONCURRENCY=2
AI_MAX_RETRIES=2
